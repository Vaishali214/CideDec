# Production environment variables for CideDec Express Backend
PORT=3001
NODE_ENV=production

# JWT configurations
JWT_SECRET=your-production-long-secure-jwt-secret-key

# Database settings
DATABASE_FILE=database.sqlite

# CORS configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://cidedec-frontend.vercel.app,http://localhost:5173

# API integration keys (optional)
GEMINI_API_KEY=your-gemini-key
RAPIDAPI_KEY=your-rapidapi-key
ADZUNA_APP_ID=your-adzuna-id
ADZUNA_APP_KEY=your-adzuna-key
